    {
      "parameters": {
        "jsCode": "const candidateArr = $('GET Candidate').first().json;\nconst candidate = Array.isArray(candidateArr) ? candidateArr[0] : candidateArr;\nconst pnRaw = $input.first().json;\nlet personnelNumber;\nif (pnRaw.data !== undefined) {\n  personnelNumber = String(pnRaw.data).replace(/^\"|\"$/g, '').trim();\n} else if (typeof pnRaw === 'string') {\n  personnelNumber = pnRaw.replace(/^\"|\"$/g, '').trim();\n} else {\n  personnelNumber = pnRaw.generate_personnel_number || Object.values(pnRaw)[0] || 'EMP00001';\n}\nif (!personnelNumber || personnelNumber === 'null') personnelNumber = 'EMP' + Date.now();\nconst today = new Date().toISOString().split('T')[0];\nif (!candidate || !candidate.id) throw new Error('Candidate not found');\nreturn [{ json: {\n  personnel_number: personnelNumber,\n  candidate_id: candidate.id,\n  first_name: candidate.first_name,\n  last_name: candidate.last_name,\n  email: candidate.email,\n  phone: candidate.phone || null,\n  date_of_birth: candidate.date_of_birth || today,\n  position_id: candidate.position_id || null,\n  org_unit_id: candidate.org_unit_id || null,\n  start_date: today,\n  status: 'active'\n} }];"
      },
