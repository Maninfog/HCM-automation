    {
      "parameters": {
        "jsCode": "const emp = $('Assemble Employee Data').first().json;\nconst insertedRow = $('INSERT Employee').first().json;\nconst employeeId = (Array.isArray(insertedRow) ? insertedRow[0]?.id : insertedRow?.id) || emp.candidate_id;\nconst onboardingLink = 'https://hcm-automation.vercel.app/onboarding?employee=' + employeeId;\nconst subject = '[DEMO — Mitarbeiter-Mail] Willkommen, ' + emp.first_name + '! Bitte Daten vervollständigen';\nconst html = '<div style=\"font-family:sans-serif;max-width:560px;margin:0 auto\">' +\n  '<div style=\"background:#1a1a2e;padding:20px 24px;border-radius:8px 8px 0 0\">' +\n  '<span style=\"color:#fff;font-weight:700;font-size:16px\">HCM Automation · Willkommen im Team!</span>' +\n  '</div>' +\n  '<div style=\"background:#f8f9fa;padding:24px;border-radius:0 0 8px 8px;border:1px solid #e9ecef\">' +\n  '<p style=\"font-size:15px;margin:0 0 16px\">Hallo <strong>' + emp.first_name + '</strong>,</p>' +\n  '<p style=\"font-size:14px;color:#495057;margin:0 0 16px\">wir freuen uns, dich im Team begrüßen zu dürfen! Um deine Gehaltsabrechnung einzurichten, benötigen wir noch einige Angaben von dir.</p>' +\n  '<div style=\"text-align:center;margin:24px 0\">' +\n  '<a href=\"' + onboardingLink + '\" style=\"background:#2563eb;color:#fff;padding:12px 28px;border-radius:6px;text-decoration:none;font-weight:600;font-size:14px\">Jetzt Daten vervollständigen →</a>' +\n  '</div>' +\n  '<p style=\"font-size:12px;color:#868e96;margin:16px 0 0\">Deine Personalnummer: <strong style=\"font-family:monospace\">' + emp.personnel_number + '</strong><br/>Eintritt: <strong>' + emp.start_date + '</strong></p>' +\n  '<hr style=\"margin:16px 0;border:none;border-top:1px solid #dee2e6\"/>' +\n  '<p style=\"font-size:11px;color:#adb5bd;margin:0\">⚠️ DEMO: Diese Mail würde im echten Betrieb an ' + emp.email + ' gesendet werden. Der obige Link ist für Demo-Zwecke funktionsfähig.</p>' +\n  '</div></div>';\nreturn [{ json: { subject, html } }];"
