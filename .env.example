# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY   # nur für n8n (Server) — nie ins Frontend!

# ── E-Mail (Resend) ──────────────────────────────────────────────────────────
# Konto: https://resend.com — kostenlos bis 3.000 Mails/Monat
RESEND_API_KEY=re_YOUR_API_KEY
HR_NOTIFY_EMAIL=you@example.com              # wer die Robot-Abschluss-Mails bekommt
MAIL_DOMAIN=hcm-demo.dev                     # muss in Resend als Sender verifiziert sein

# ── n8n ─────────────────────────────────────────────────────────────────────
# Basis-URL der n8n-Instanz (kein trailing slash) — für interne Webhook-Aufrufe
HCM_N8N_BASE_URL=https://YOUR_N8N_INSTANCE.app.n8n.cloud
# Optional: Slack Webhook für Workflow 04
SLACK_WEBHOOK_URL=

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
# Diese Variablen in Vercel Project Settings → Environment Variables eintragen
# NEXT_PUBLIC_ / VITE_ Prefix je nach Framework (Lovable/TanStack: VITE_)
HCM_DASHBOARD_URL=https://YOUR_PROJECT.vercel.app
